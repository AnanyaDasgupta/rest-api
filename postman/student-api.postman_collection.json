{
  "info": {
    "name": "Student REST API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "CRUD API collection for student resource"
  },
  "item": [
    {
      "name": "Healthcheck",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/healthcheck",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "healthcheck"
          ]
        }
      }
    },
    {
      "name": "Create Student",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"first_name\": \"Ada\",\n  \"last_name\": \"Lovelace\",\n  \"email\": \"ada@example.com\",\n  \"age\": 20\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/students",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "students"
          ]
        }
      }
    },
    {
      "name": "List Students",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/students",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "students"
          ]
        }
      }
    },
    {
      "name": "Get Student By ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/students/:id",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "students",
            ":id"
          ]
        }
      }
    },
    {
      "name": "Update Student",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"age\": 21\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/students/:id",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "students",
            ":id"
          ]
        }
      }
    },
    {
      "name": "Delete Student",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/api/v1/students/:id",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "students",
            ":id"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    }
  ]
}
